{
  "Next.js Page Component": {
    "prefix": "npage",
    "body": [
      "export default function ${1:Page}() {",
      "  return (",
      "    <main>",
      "      $0",
      "    </main>",
      "  );",
      "}"
    ],
    "description": "Next.js App Router page component"
  },
  "Next.js Layout Component": {
    "prefix": "nlayout",
    "body": [
      "export default function ${1:Layout}({ children }) {",
      "  return (",
      "    <section>",
      "      {children}",
      "    </section>",
      "  );",
      "}"
    ],
    "description": "Next.js layout component"
  },
  "Next.js API Route": {
    "prefix": "apiroute",
    "body": [
      "import { NextResponse } from 'next/server';",
      "",
      "export async function GET() {",
      "  return NextResponse.json({ ok: true });",
      "}",
      "",
      "export async function POST(request) {",
      "  const payload = await request.json();",
      "  return NextResponse.json({ data: payload }, { status: 201 });",
      "}"
    ],
    "description": "Next.js App Router route handler"
  },
  "Next.js Middleware": {
    "prefix": "middleware",
    "body": [
      "import { NextResponse } from 'next/server';",
      "",
      "export function middleware(request) {",
      "  const response = NextResponse.next();",
      "  return response;",
      "}",
      "",
      "export const config = {",
      "  matcher: ['${1:/((?!api|_next/static|_next/image|favicon.ico).*)}'],",
      "};"
    ],
    "description": "Next.js Middleware"
  },
  "Next.js Link": {
    "prefix": "nlink",
    "body": ["<Link href=\"$1\">$2</Link>"],
    "description": "Next.js Link component"
  },
  "Next.js Image": {
    "prefix": "nimg",
    "body": [
      "import Image from 'next/image';",
      "",
      "<Image",
      "  src=\"${1:/images/example.png}\"",
      "  alt=\"${2:Image description}\"",
      "  width={${3:1200}}",
      "  height={${4:800}}",
      "  sizes=\"${5:(max-width: 768px) 100vw, 50vw}\"",
      "  className=\"${6:object-cover}\"",
      "/>"
    ],
    "description": "Next.js Image component with responsive sizing"
  },
  "React Functional Component": {
    "prefix": "rfc",
    "body": [
      "const ${1:ComponentName} = () => {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  );",
      "};",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "React Functional Component"
  },
  "React Functional Component (function)": {
    "prefix": "rff",
    "body": [
      "export default function ${1:ComponentName}() {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "React Functional Component (function declaration)"
  },
  "useState Hook": {
    "prefix": "us",
    "body": ["const [${1:state}, set${1:state}] = useState($2);"],
    "description": "React useState Hook"
  },
  "useEffect (with deps)": {
    "prefix": "ue",
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, [${1:deps}]);"
    ],
    "description": "useEffect Hook"
  },
  "useEffect (mount only)": {
    "prefix": "uem",
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, []);"
    ],
    "description": "useEffect runs once at mount"
  },
  "useEffect (every render)": {
    "prefix": "uer",
    "body": [
      "useEffect(() => {",
      "  $0",
      "});"
    ],
    "description": "useEffect runs on every render"
  },
  "useEffect Cleanup": {
    "prefix": "cleanup",
    "body": [
      "return () => {",
      "  $0",
      "};"
    ],
    "description": "useEffect cleanup function"
  },
  "useRef": {
    "prefix": "urf",
    "body": ["const ${1:ref} = useRef(null);"],
    "description": "React useRef Hook"
  },
  "useContext": {
    "prefix": "uctx",
    "body": ["const ${1:value} = useContext(${2:Context});"],
    "description": "React useContext Hook"
  },
  "useMemo": {
    "prefix": "ume",
    "body": [
      "const ${1:value} = useMemo(() => {",
      "  $0",
      "}, [${2:deps}]);"
    ],
    "description": "useMemo Hook"
  },
  "useCallback": {
    "prefix": "ucb",
    "body": [
      "const ${1:fn} = useCallback(() => {",
      "  $0",
      "}, [${2:deps}]);"
    ],
    "description": "useCallback Hook"
  },
  "Custom Hook": {
    "prefix": "hk",
    "body": [
      "import { useState } from 'react';",
      "",
      "function use${1:Custom}(initialValue) {",
      "  const [state, setState] = useState(initialValue);",
      "",
      "  const update = (value) => {",
      "    setState(value);",
      "  };",
      "",
      "  return { state, update };",
      "}",
      "",
      "export default use${1:Custom};"
    ],
    "description": "Custom hook boilerplate"
  },
  "React Context": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useContext } from 'react';",
      "",
      "const ${1:Name}Context = createContext(null);",
      "",
      "export function ${1:Name}Provider({ children, ${2:value} }) {",
      "  return (",
      "    <${1:Name}Context.Provider value={{ ${2:value} }}>",
      "      {children}",
      "    </${1:Name}Context.Provider>",
      "  );",
      "}",
      "",
      "export function use${1:Name}() {",
      "  const context = useContext(${1:Name}Context);",
      "",
      "  if (!context) {",
      "    throw new Error('use${1:Name} must be used within ${1:Name}Provider');",
      "  }",
      "",
      "  return context;",
      "}"
    ],
    "description": "Simple React Context provider and hook"
  },
  "React Fragment": {
    "prefix": "frag",
    "body": ["<>", "  $0", "</>"],
    "description": "React Fragment shorthand"
  },
  "Async fetch": {
    "prefix": "apifetch",
    "body": [
      "const fetchData = async () => {",
      "  try {",
      "    const response = await fetch('${1:/api/endpoint}', {",
      "      method: '${2:GET}',",
      "      headers: {",
      "        'Content-Type': 'application/json',",
      "      },",
      "    });",
      "",
      "    if (!response.ok) {",
      "      throw new Error('Request failed with status ' + response.status);",
      "    }",
      "",
      "    const data = await response.json();",
      "    $0",
      "    return data;",
      "  } catch (error) {",
      "    console.error('Fetch request failed:', error);",
      "    throw error;",
      "  }",
      "};"
    ],
    "description": "Async fetch request with status handling"
  },
  "Console Log": {
    "prefix": "clg",
    "body": ["console.log($1);"],
    "description": "console.log"
  }
}
