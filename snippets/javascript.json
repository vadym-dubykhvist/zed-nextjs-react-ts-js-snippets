{
  "Next.js Page Component": {
    "prefix": "npage",
    "body": [
      "const ${1:ComponentName} = () => {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  );",
      "};",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "Next.js page component"
  },
  "Next.js Layout Component": {
    "prefix": "nlayout",
    "body": [
      "export default function Layout({ children }) {",
      "  return (",
      "    <div>",
      "      {children}",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "Next.js Layout component"
  },
  "Next.js API Route": {
    "prefix": "apiroute",
    "body": [
      "export default function handler(req, res) {",
      "  if (req.method === 'GET') {",
      "    res.status(200).json({ message: 'Hello' });",
      "  } else {",
      "    res.status(405).end();",
      "  }",
      "}"
    ],
    "description": "Next.js API route handler"
  },
  "Next.js Middleware": {
    "prefix": "middleware",
    "body": [
      "import { NextResponse } from 'next/server';",
      "",
      "export function middleware(request) {",
      "  return NextResponse.next();",
      "}",
      "",
      "export const config = {",
      "  matcher: ['$1'],",
      "};"
    ],
    "description": "Next.js Middleware"
  },
  "Next.js Link": {
    "prefix": "nlink",
    "body": ["<Link href=\"$1\">$2</Link>"],
    "description": "Next.js Link component"
  },
  "Next.js Image": {
    "prefix": "nimg",
    "body": [
      "import Image from 'next/image';",
      "",
      "<Image src=\"$1\" alt=\"$2\" width={$3} height={$4} />"
    ],
    "description": "Next.js Image component"
  },
  "React Functional Component": {
