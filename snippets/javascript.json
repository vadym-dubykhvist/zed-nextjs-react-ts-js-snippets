  },
  "Custom Hook": {
    "prefix": "hk",
    "body": [
      "import { useState } from 'react';",
      "",
      "function use${1:Custom}(initialValue) {",
      "  const [state, setState] = useState(initialValue);",
      "",
      "  const update = (value) => {",
      "    setState(value);",
      "  };",
      "",
      "  return { state, update };",
      "}",
      "",
      "export default use${1:Custom};"
    ],
    "description": "Custom hook boilerplate"
  },
  "React Context": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useState, useContext } from 'react';",
      "",
      "const ${1:Name}Context = createContext(null);",
      "",
      "export function ${1:Name}Provider({ children }) {",
      "  const [${2:state}, set${2:state}] = useState($3);",
      "  return (",
      "    <${1:Name}Context.Provider value={{ ${2:state}, set${2:state} }}>",
      "      {children}",
      "    </${1:Name}Context.Provider>",
      "  );",
      "}",
      "",
      "export function use${1:Name}() {",
      "  const ctx = useContext(${1:Name}Context);",
      "  if (!ctx) throw new Error('use${1:Name} must be used within ${1:Name}Provider');",
      "  return ctx;",
      "}"
    ],
    "description": "React Context with Provider and custom hook"
  },
  "React Fragment": {
    "prefix": "frag",
    "body": ["<>", "  $0", "</>"],
    "description": "React Fragment shorthand"
  },
  "Async fetch": {
    "prefix": "apifetch",
    "body": [
      "const fetchData = async () => {",
      "  try {",
      "    const response = await fetch('$1');",
      "    const data = await response.json();",
      "    $0",
      "  } catch (error) {",
      "    console.error(error);",
      "  }",
      "};"
    ],
    "description": "Async/await fetch API call"
  },
  "Console Log": {
    "prefix": "clg",
    "body": ["console.log($1);"],
    "description": "console.log"
  }
}
