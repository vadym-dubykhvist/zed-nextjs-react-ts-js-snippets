{
  "Type Alias": {
    "prefix": "tst",
    "body": ["type ${1:TypeName} = {", "  ${2:key}: ${3:type};", "};"],
    "description": "Type alias"
  },
  "Interface": {
    "prefix": "tsi",
    "body": ["interface ${1:InterfaceName} {", "  ${2:key}: ${3:type};", "}"],
    "description": "Interface"
  },
  "Enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "  $0", "}"],
    "description": "Enum"
  },
  "Function Declaration": {
    "prefix": "tsfn",
    "body": ["function ${1:name}(${2:args}: ${3:type}): ${4:void} {", "  $0", "}"],
    "description": "Function declaration with types"
  },
  "Arrow Function": {
    "prefix": "tsafn",
    "body": ["const ${1:name} = (${2:args}: ${3:type}): ${4:void} => {", "  $0", "};"],
    "description": "Arrow function with types"
  },
  "Typed Fetch Function": {
    "prefix": "tsfetch",
    "body": [
      "type ${1:ResponseData}RequestOptions = RequestInit & {",
      "  signal?: AbortSignal;",
      "};",
      "",
      "export async function get${1:ResponseData}(",
      "  url: string,",
      "  options: ${1:ResponseData}RequestOptions = {},",
      "): Promise<${1:ResponseData}> {",
      "  const response = await fetch(url, options);",
      "",
      "  if (!response.ok) {",
      "    throw new Error('GET ' + response.url + ' failed with ' + response.status);",
      "  }",
      "",
      "  return (await response.json()) as ${1:ResponseData};",
      "}"
    ],
    "description": "Typed fetch helper with request options"
  },
  "Try/Catch": {
    "prefix": "tstc",
    "body": [
      "try {",
      "  $0",
      "} catch (error) {",
      "  const message = error instanceof Error ? error.message : 'Unknown error';",
      "",
      "  throw new Error('${1:Operation} failed: ' + message, {",
      "    cause: error,",
      "  });",
      "}"
    ],
    "description": "try/catch that preserves unknown error cause"
  },
  "Type Guard": {
    "prefix": "tgf",
    "body": [
      "function is${1:TypeName}(value: unknown): value is ${1:TypeName} {",
      "  if (typeof value !== 'object' || value === null) {",
      "    return false;",
      "  }",
      "",
      "  return '${2:property}' in value;",
      "}"
    ],
    "description": "Object type guard by property presence"
  },
  "Record Type": {
    "prefix": "tsrcd",
    "body": [
      "const ${1:record}: Record<${2:string}, ${3:number}> = {",
      "  ${4:key}: ${5:value},",
      "};"
    ],
    "description": "Record utility type"
  },
  "Class with Constructor": {
    "prefix": "tscls",
    "body": [
      "class ${1:ClassName} {",
      "  constructor(${2:args}) {",
      "    $0",
      "  }",
      "}"
    ],
    "description": "Class with constructor"
  },
  "Service Class": {
    "prefix": "tsserv",
    "body": [
      "interface ${1:ServiceName}Dependencies {",
      "  ${2:client}: ${3:Client};",
      "}",
      "",
      "export class ${1:ServiceName}Service {",
      "  constructor(private readonly deps: ${1:ServiceName}Dependencies) {}",
      "",
      "  async run(${4:input}: ${5:Input}): Promise<${6:Result}> {",
      "    const { ${2:client} } = this.deps;",
      "    $0",
      "    return ${7:result};",
      "  }",
      "}"
    ],
    "description": "Service class with typed dependencies"
  },
  "Import Statement": {
    "prefix": "tsimprt",
    "body": ["import { ${1:thing} } from '${2:module}';"],
    "description": "Named import"
  },
  "Export Statement": {
    "prefix": "tsxprt",
    "body": ["export { $0 };"],
    "description": "Export members"
  },
  "Console Log": {
    "prefix": "clg",
    "body": ["console.log($1);"],
    "description": "console.log"
  }
}
