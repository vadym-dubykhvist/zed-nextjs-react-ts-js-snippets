{
  "Next.js Page Component": {
    "prefix": "npage",
    "body": [
      "export default function ${1:Page}() {",
      "  return (",
      "    <main>",
      "      $0",
      "    </main>",
      "  );",
      "}"
    ],
    "description": "Next.js App Router page component"
  },
  "Next.js Layout Component": {
    "prefix": "nlayout",
    "body": [
      "import type { ReactNode } from 'react';",
      "",
      "type LayoutProps = Readonly<{",
      "  children: ReactNode;",
      "}>;",
      "",
      "export default function ${1:Layout}({ children }: LayoutProps) {",
      "  return (",
      "    <section>",
      "      {children}",
      "    </section>",
      "  );",
      "}"
    ],
    "description": "Typed Next.js layout component"
  },
  "Next.js API Route": {
    "prefix": "apiroute",
    "body": [
      "import { NextRequest, NextResponse } from 'next/server';",
      "",
      "export async function GET(request: NextRequest) {",
      "  return NextResponse.json({ message: 'Hello' });",
      "}",
      "",
      "export async function POST(request: NextRequest) {",
      "  const body = await request.json();",
      "  return NextResponse.json({ data: body }, { status: 201 });",
      "}"
    ],
    "description": "Next.js App Router API route handler"
  },
  "Next.js Middleware": {
    "prefix": "middleware",
    "body": [
      "import { NextResponse } from 'next/server';",
      "import type { NextRequest } from 'next/server';",
      "",
      "export function middleware(request: NextRequest) {",
      "  return NextResponse.next();",
      "}",
      "",
      "export const config = {",
      "  matcher: ['$1'],",
      "};"
    ],
    "description": "Next.js Middleware"
  },
  "Next.js Link": {
    "prefix": "nlink",
    "body": ["<Link href=\"$1\">$2</Link>"],
    "description": "Next.js Link component"
  },
  "Next.js Image": {
    "prefix": "nimg",
    "body": [
      "import Image from 'next/image';",
      "",
      "<Image",
      "  src=\"${1:/images/example.png}\"",
      "  alt=\"${2:Image description}\"",
      "  width={${3:1200}}",
      "  height={${4:800}}",
      "  sizes=\"${5:(max-width: 768px) 100vw, 50vw}\"",
      "  className=\"${6:object-cover}\"",
      "/>"
    ],
    "description": "Next.js Image component with responsive sizing"
  },
  "React Functional Component (const)": {
    "prefix": "rfc",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  $2",
      "}",
      "",
      "const ${1:ComponentName} = ({ $3 }: ${1:ComponentName}Props) => {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  );",
      "};",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "React Functional Component with TypeScript props"
  },
  "React Functional Component (function)": {
    "prefix": "rff",
    "body": [
      "interface ${1:ComponentName}Props {",
      "  $2",
      "}",
      "",
      "export default function ${1:ComponentName}({ $3 }: ${1:ComponentName}Props) {",
      "  return (",
      "    <div>",
      "      $0",
      "    </div>",
      "  );",
      "}"
    ],
    "description": "React Functional Component (function declaration)"
  },
  "ForwardRef Component": {
    "prefix": "frc",
    "body": [
      "import { forwardRef, type ComponentPropsWithoutRef } from 'react';",
      "",
      "type ${1:ComponentName}Props = ComponentPropsWithoutRef<'${2:button}'> & {",
      "  ${3:variant}?: '${4:primary}' | '${5:secondary}';",
      "};",
      "",
      "const ${1:ComponentName} = forwardRef<${6:HTMLButtonElement}, ${1:ComponentName}Props>(",
      "  ({ ${3:variant} = '${4:primary}', className, ...props }, ref) => {",
      "    return (",
      "      <${2:button}",
      "        ref={ref}",
      "        data-variant={${3:variant}}",
      "        className={className}",
      "        {...props}",
      "      />",
      "    );",
      "  },",
      ");",
      "",
      "${1:ComponentName}.displayName = '${1:ComponentName}';",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "ForwardRef component with native element props"
  },
  "useState Hook": {
    "prefix": "us",
    "body": [
      "const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState<${2:type}>(${3:initialValue});"
    ],
    "description": "useState Hook with TypeScript"
  },
  "useEffect (with deps)": {
    "prefix": "ue",
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, [${1:deps}]);"
    ],
    "description": "useEffect Hook"
  },
  "useEffect (mount only)": {
    "prefix": "uem",
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, []);"
    ],
    "description": "useEffect Hook runs once at mount"
  },
  "useEffect (every render)": {
    "prefix": "uer",
    "body": [
      "useEffect(() => {",
      "  $0",
      "});"
    ],
    "description": "useEffect Hook runs on every render"
  },
  "useEffect Cleanup": {
    "prefix": "cleanup",
    "body": [
      "return () => {",
      "  $0",
      "};"
    ],
    "description": "useEffect cleanup function"
  },
  "useRef": {
    "prefix": "urf",
    "body": ["const ${1:ref} = useRef<${2:HTMLDivElement}>(${3:null});"],
    "description": "useRef Hook with TypeScript"
  },
  "useContext": {
    "prefix": "uctx",
    "body": ["const ${1:value} = useContext(${2:Context});"],
    "description": "useContext Hook"
  },
  "useMemo": {
    "prefix": "ume",
    "body": [
      "const ${1:value} = useMemo(() => {",
      "  $0",
      "}, [${2:deps}]);"
    ],
    "description": "useMemo Hook"
  },
  "useCallback": {
    "prefix": "ucb",
    "body": [
      "const ${1:fn} = useCallback(() => {",
      "  $0",
      "}, [${2:deps}]);"
    ],
    "description": "useCallback Hook"
  },
  "useReducer": {
    "prefix": "ur",
    "body": [
      "const [state, dispatch] = useReducer(${1:reducer}, ${2:initialState});"
    ],
    "description": "useReducer Hook"
  },
  "Custom Hook": {
    "prefix": "hk",
    "body": [
      "import { useState, useCallback } from 'react';",
      "",
      "export function use${1:Name}<T = ${2:unknown}>(initial: T) {",
      "  const [value, setValue] = useState<T>(initial);",
      "",
      "  const reset = useCallback(() => setValue(initial), [initial]);",
      "",
      "  return { value, setValue, reset } as const;",
      "}"
    ],
    "description": "Custom hook with generic type, reset, and const return"
  },
  "React Context": {
    "prefix": "rctx",
    "body": [
      "import { createContext, useContext, type ReactNode } from 'react';",
      "",
      "type ${1:Name}ContextValue = {",
      "  ${2:value}: ${3:string};",
      "};",
      "",
      "const ${1:Name}Context = createContext<${1:Name}ContextValue | null>(null);",
      "",
      "export function ${1:Name}Provider({",
      "  children,",
      "  ${2:value},",
      "}: {",
      "  children: ReactNode;",
      "  ${2:value}: ${3:string};",
      "}) {",
      "  return (",
      "    <${1:Name}Context.Provider value={{ ${2:value} }}>",
      "      {children}",
      "    </${1:Name}Context.Provider>",
      "  );",
      "}",
      "",
      "export function use${1:Name}() {",
      "  const context = useContext(${1:Name}Context);",
      "",
      "  if (!context) {",
      "    throw new Error('use${1:Name} must be used within ${1:Name}Provider');",
      "  }",
      "",
      "  return context;",
      "}"
    ],
    "description": "Simple typed React Context provider and hook"
  },
  "React Fragment": {
    "prefix": "frag",
    "body": ["<>", "  $0", "</>"],
    "description": "React Fragment shorthand"
  },
  "Next.js Error Boundary": {
    "prefix": "nerror",
    "body": [
      "'use client';",
      "",
      "import { useEffect } from 'react';",
      "",
      "type ErrorPageProps = {",
      "  error: Error & { digest?: string };",
      "  reset: () => void;",
      "};",
      "",
      "export default function ErrorPage({",
      "  error,",
      "  reset,",
      "}: ErrorPageProps) {",
      "  useEffect(() => {",
      "    console.error(error);",
      "  }, [error]);",
      "",
      "  return (",
      "    <main>",
      "      <h2>Something went wrong!</h2>",
      "      <button type=\"button\" onClick={reset}>",
      "        Try again",
      "      </button>",
      "    </main>",
      "  );",
      "}"
    ],
    "description": "Next.js error boundary client component"
  },
  "Console Log": {
    "prefix": "clg",
    "body": ["console.log($1);"],
    "description": "console.log"
  }
}
